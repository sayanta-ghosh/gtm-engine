# =============================================================================
# nrev-lite — Environment Configuration
# =============================================================================
#
# SETUP INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in the values below (see comments for each)
#   3. Place the .env file in the PROJECT ROOT (same folder as this file,
#      next to pyproject.toml and docker-compose.yml).
#      The server auto-loads it from the working directory.
#
# The .env file is gitignored and will NEVER be committed.
# Share secrets via a password manager (1Password, Bitwarden), not git/email/Slack.
# =============================================================================


# =============================================================================
# REQUIRED — Server will NOT start without these
# =============================================================================

# --- Database (PostgreSQL 15+) ---
# Local dev (matches docker-compose.yml):
DATABASE_URL=postgresql+asyncpg://nrev_lite:nrev_lite_local_dev@localhost:5432/nrev_lite
# Production example:
# DATABASE_URL=postgresql+asyncpg://nrev_lite_api:PASSWORD@your-aurora-cluster.region.rds.amazonaws.com:5432/nrev_lite

# --- Redis ---
# Local dev:
REDIS_URL=redis://localhost:6379/0
# Production example:
# REDIS_URL=redis://your-elasticache-cluster.region.cache.amazonaws.com:6379/0

# --- JWT Authentication ---
# Generate a strong secret: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# CRITICAL: Change this from the default in production!
JWT_SECRET_KEY=CHANGE-ME-generate-a-strong-random-secret-at-least-32-chars
# JWT_ALGORITHM=HS256                    # default, no need to change
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440   # 24 hours, default
# JWT_REFRESH_TOKEN_EXPIRE_DAYS=30       # default

# --- Google OAuth ---
# Create at: https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorized redirect URI must match GOOGLE_REDIRECT_URI below
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback
# Production: GOOGLE_REDIRECT_URI=https://api.yourdomain.com/api/v1/auth/callback


# =============================================================================
# OPTIONAL — Platform-managed provider API keys
# =============================================================================
# These are nrev-lite's own keys, used when tenants don't bring their own (BYOK).
# Calls using platform keys charge credits; BYOK calls are free.
# Leave blank to disable that provider for platform-key usage.

# Apollo.io — person/company enrichment & search
# Sign up: https://apollo.io
APOLLO_API_KEY=

# RocketReach — contact finding, school/alumni search
# Sign up: https://rocketreach.co
ROCKETREACH_API_KEY=
# ROCKETREACH_API=                      # alias, some users set this instead

# RapidAPI — Google Search (Real-Time Web Search by OpenWeb Ninja)
# Sign up: https://rapidapi.com, subscribe to "Real-Time Web Search"
X_RAPIDAPI_KEY=
# RAPIDAPI_KEY=                         # alias

# Parallel Web Systems — web scraping & AI-powered research
# Sign up: https://parallel.ai
PARALLEL_KEY=

# PredictLeads — company intelligence (funding, hiring, tech stack)
# Sign up: https://predictleads.com
PREDICTLEADS_API_KEY=
# PREDICTLEADS_API_TOKEN=               # alias

# Composio — OAuth app connections (Slack, Gmail, HubSpot, etc.)
# Sign up: https://composio.dev
# Required for the Connections tab in the dashboard
COMPOSIO_API_KEY=


# =============================================================================
# OPTIONAL — Payments & Cloud
# =============================================================================

# Stripe — credit purchases & billing
# Get keys: https://dashboard.stripe.com/apikeys
# Webhook endpoint: https://yourdomain.com/api/v1/credits/webhook
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# AWS — for KMS (key encryption) and S3 (dashboard hosting) in production
AWS_REGION=us-east-1

# Environment — controls CORS, logging, encryption mode
# "development" = permissive CORS, Fernet encryption, debug logging
# "production"  = restricted CORS, KMS encryption, info logging
ENVIRONMENT=development
