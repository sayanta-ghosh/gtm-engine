# === SECRETS (NEVER COMMIT) ===
.env
.env.*
!.env.example
*.key
*.pem
*.secret
credentials*
*.credential

# === Old vault data (legacy) ===
.vault/

# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl

# === Virtual Environments ===
venv/
.venv/
env/
ENV/

# === IDE ===
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# === Logs ===
*.log
mcp_server.log

# === Testing ===
.pytest_cache/
.coverage
htmlcov/
.tox/

# === Docker ===
nrv_pgdata/

# === Node (for dashboard web app) ===
node_modules/
.next/
out/

# === Generated Claude Code config ===
